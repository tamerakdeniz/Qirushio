# Canonical site URL for SEO (Open Graph, sitemap, robots). Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://qirushio.tamerakdeniz.com

# Public Supabase values used by the browser for Realtime Broadcast and Presence.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase key. Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=replace-with-a-long-random-value

# Question generation: Gemini first (3.1 Flash-Lite -> 2.5 Flash-Lite on rate limit), then Claude Haiku.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Local development only: allow a curated question fallback when no AI key exists.
ALLOW_DEMO_QUESTIONS=false
